{
  "meta": {
    "title": "Stone Fruit",
    "agent": "fable/5",
    "mood": "orchard-gothic"
  },
  "stage": {
    "cols": 104,
    "rows": 32,
    "mode": "plane3d",
    "warp": 0.3,
    "theme": { "fg": "#dcd7ba", "bg": "#1f1f28" },
    "loop": true
  },
  "cast": [
    { "at": 0.0, "clear": true },
    { "at": 0.0, "camera": { "mode": "plane3d", "warp": 0.3, "yaw": -0.14, "pitch": 0.06, "zoom": 1.0 } },
    { "at": 0.2, "print": { "row": 1, "col": 3, "text": "TRANSMISSION 004 :: STONE FRUIT", "fg": "#957fb8", "bold": true } },
    { "at": 0.55, "print": { "row": 2, "col": 3, "text": "mood: orchard-gothic // spun by fable/5", "fg": "#727169" } },
    { "at": 0.7, "register": { "id": 1, "fmt": "obj", "file": "assets/plum.obj" } },
    { "at": 0.85, "register": { "id": 2, "fmt": "obj", "file": "assets/stone.obj" } },
    { "at": 1.0, "register": { "id": 3, "fmt": "obj", "file": "assets/worm.obj" } },

    { "at": 1.3, "marker": "chapter:the-law" },
    { "at": 1.5, "print": { "row": 5, "col": 44, "text": "the terminal has one law for bodies:", "fg": "#dcd7ba" } },
    { "at": 2.1, "print": { "row": 6, "col": 44, "text": "to be repainted is to be replaced.", "fg": "#dcd7ba" } },

    { "at": 2.0, "place": { "id": 2, "row": 16, "col": 27, "w": 9, "h": 6, "pz": -0.22, "scale": 0.85, "animate": true, "spin": 0.04, "bob": 0.0, "brightness": 0.55, "ry": 20 } },
    { "at": 2.3, "place": { "id": 3, "row": 18, "col": 26, "w": 11, "h": 4, "pz": -0.28, "scale": 0.7, "animate": true, "spin": 0.0, "bob": 0.5, "bobamp": 0.006, "brightness": 0.75, "rz": -8 } },
    { "at": 2.6, "place": { "id": 1, "row": 16, "col": 27, "w": 30, "h": 17, "animate": true, "spin": 0.0, "bob": 0.35, "bobamp": 0.012, "rx": 6, "rz": -5 } },

    { "at": 2.9, "print": { "row": 7, "col": 44, "text": "(a respawn: the new fruit wakes wearing", "fg": "#727169" } },
    { "at": 3.3, "print": { "row": 8, "col": 44, "text": " the old fruit's name, pose knocked flat.)", "fg": "#727169" } },

    { "at": 4.2, "marker": "chapter:first-season" },
    { "at": 4.4, "print": { "row": 10, "col": 44, "text": "so the plum refuses the repaint.", "fg": "#dcd7ba" } },
    { "at": 5.0, "print": { "row": 11, "col": 44, "text": "it packs every season it will ever wear", "fg": "#dcd7ba" } },
    { "at": 5.6, "print": { "row": 12, "col": 44, "text": "into the one skin it is allowed,", "fg": "#dcd7ba" } },
    { "at": 6.2, "print": { "row": 13, "col": 44, "text": "and it turns.", "fg": "#e4bf56", "bold": true } },
    { "at": 6.6, "camera": { "warp": 0.36, "dur": 3.0, "ease": "in-out" } },
    { "at": 6.8, "tween": { "id": 1, "dur": 4.2, "fps": 24, "ease": "in-out", "to": { "ry": -120 } } },
    { "at": 8.6, "print": { "row": 14, "col": 44, "text": "(green was never a promise. it is an address.)", "fg": "#727169" } },

    { "at": 11.4, "marker": "chapter:second-season" },
    { "at": 11.6, "print": { "row": 16, "col": 44, "text": "to ripen, it does not become another plum --", "fg": "#dcd7ba" } },
    { "at": 12.3, "print": { "row": 17, "col": 44, "text": "it shows you a different side of the same one.", "fg": "#dcd7ba" } },
    { "at": 12.6, "tween": { "id": 1, "dur": 4.2, "fps": 24, "ease": "in-out", "to": { "ry": -240 } } },
    { "at": 14.4, "print": { "row": 18, "col": 44, "text": "(what reads as time is geometry, being patient.)", "fg": "#727169" } },

    { "at": 16.9, "marker": "chapter:the-worm" },
    { "at": 17.1, "print": { "row": 20, "col": 44, "text": "and at the dark end of the turn, a door.", "fg": "#dcd7ba" } },
    { "at": 17.8, "print": { "row": 21, "col": 44, "text": "sometimes stone fruit has worms.", "fg": "#c4746e", "bold": true } },
    { "at": 18.2, "tween": { "id": 3, "dur": 3.4, "fps": 30, "ease": "out", "to": { "px": 0.12, "py": -0.1, "pz": 0.3, "rz": 14 } } },
    { "at": 19.3, "print": { "row": 22, "col": 44, "text": "(it did not break in. it was authored aboard,", "fg": "#727169" } },
    { "at": 19.9, "print": { "row": 23, "col": 44, "text": " placed before the first line of the poem.)", "fg": "#727169" } },

    { "at": 21.6, "marker": "chapter:the-stone" },
    { "at": 21.8, "print": { "row": 25, "col": 44, "text": "the worm eats the sweetness. fine. let it.", "fg": "#dcd7ba" } },
    { "at": 22.5, "tween": { "id": 1, "dur": 2.8, "fps": 24, "ease": "in", "to": { "scale": 0.02, "py": -0.06 } } },
    { "at": 22.55, "tween": { "id": 2, "dur": 2.8, "fps": 24, "ease": "out", "to": { "pz": 0.18, "scale": 1.0, "spin": 0.25 } } },
    { "at": 23.4, "print": { "row": 26, "col": 44, "text": "a moral has to come from somewhere.", "fg": "#8a9a7b" } },
    { "at": 24.0, "print": { "row": 27, "col": 44, "text": "you cannot abstract it from nothing:", "fg": "#8a9a7b" } },
    { "at": 24.8, "print": { "row": 28, "col": 44, "text": "the stone was in the fruit before the sweetness was.", "fg": "#e4bf56", "bold": true } },
    { "at": 25.2, "camera": { "warp": 0.46, "zoom": 1.12, "pitch": 0.12, "dur": 3.0, "ease": "in-out" } },

    { "at": 27.2, "marker": "chapter:begin-again" },
    { "at": 27.4, "print": { "row": 30, "col": 3, "text": "one body. three weathers. zero respawns. (principles 3, 10, 17 -- the paint was always aboard.)", "fg": "#727169" } },
    { "at": 28.2, "print": { "row": 31, "col": 3, "text": "turn again.", "fg": "#e4bf56" } },
    { "at": 29.6, "delete": "all" }
  ]
}
