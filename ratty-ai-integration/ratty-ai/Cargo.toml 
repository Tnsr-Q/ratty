[package]
name = "ratty-ai"
version = "0.2.0"
edition = "2021"
authors = ["ratty-ai contributors"]
description = "Enhanced CLI control for Ratty terminal emulator"
license = "MIT"
repository = "https://github.com/orhun/ratty"
keywords = ["ratty", "terminal", "cli", "osc", "3d", "ai"]
categories = ["command-line-utilities"]

[dependencies]
clap = { version = "4.5", features = ["derive", "cargo"] }
urlencoding = "2.1"

[profile.release]
opt-level = 3
lto = true
strip = true
