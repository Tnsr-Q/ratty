{"nodes": [{"id": "readme_ratty", "label": "Ratty Terminal Emulator", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A GPU-rendered terminal emulator with inline 3D graphics, inspired by TempleOS and built with Rust and Ratatui; features a spinning rat cursor, 2D and 3D modes, inline 3D objects, and Kitty-protocol image support."}, {"id": "readme_3d_mode", "label": "3D Mode", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Toggled with Ctrl+Alt+Enter to reveal the scene behind the terminal surface; warp amount is adjustable and a Mobius mode variant exists."}, {"id": "readme_spinning_rat_cursor", "label": "Spinning Rat Cursor", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Customizable 3D cursor model (cursor.model in ratty.toml) supporting .obj, .glb and .stl assets with scale_factor, brightness, x_offset, plane_offset, visibility and spin/bob animation settings."}, {"id": "readme_rendering_pipeline", "label": "GPU Rendering Pipeline", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Terminal image stays fully GPU-resident: PTY output parsed by vt100 into a Ratatui buffer on CPU, shaped by parley_ratatui into a Vello scene, handed to Bevy's render world through a double-buffered exchange (scenes recycled, never cloned or re-recorded); Vello renders into an Rgba8Unorm storage texture with no CPU readback, then it is copied to an Rgba8UnormSrgb present texture sampled through an sRGB view so Vello's sRGB-encoded output is decoded on sample instead of re-encoded. Only the recorded scene crosses from main world to render world each frame, not pixels."}, {"id": "readme_kitty_graphics_protocol", "label": "Kitty Graphics Protocol Image Support", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Ratty renders inline images via the Kitty Graphics Protocol (experimental), separate from its own RGP for 3D objects."}, {"id": "readme_ratatui", "label": "Ratatui", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_parley_ratatui", "label": "parley_ratatui", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_bevy", "label": "Bevy Engine", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_vello", "label": "Vello Renderer", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_wgpu", "label": "wgpu", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_vt100", "label": "vt100 Parser", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_ratscad", "label": "Ratscad Terminal CAD", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_ratty_runner", "label": "Ratty-runner Endless Runner", "file_type": "concept", "source_file": "README.