{"nodes": [{"id": "protocols_graphics_ratty_graphics_protocol", "label": "Ratty Graphics Protocol (RGP)", "file_type": "concept", "source_file": "protocols/graphics.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Custom terminal protocol that attaches a semantic 3D graphics object to terminal cells so it becomes part of the terminal surface rather than an external overlay. Design goals: support 3D assets directly, anchor objects to cell positions, make graphics native terminal objects, and allow future interactive behavior (clicking, macros, object state updates). Foundation for 'sprites on the command line'."}, {"id": "protocols_graphics_apc_transport", "label": "APC Escape Sequence Transport", "file_type": "concept", "source_file": "protocols/graphics.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "RGP rides on APC (Application Program Command): ESC _ ratty;g;<verb>[;key=value...] ESC \\, where ratty is the namespace and g means graphics."}, {"id": "protocols_graphics_support_query", "label": "Support Query Verb (s)", "file_type": "concept", "source_file": "protocols/graphics.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Feature detection: terminal replies with version and capability flags (fmt, path, payload, chunk, anim, depth, color, brightness, transform, update, normalize); no reply means no protocol support."}, {"id": "protocols_graphics_register_object_asset", "label": "Register Object Asset Verb (r)", "file_type": "concept", "source_file": "protocols/graphics.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Registers a 3D object by application-chosen id with fmt obj/glb/stl; supports path-based and payload-based sources additively, plus an OBJ normalize flag (center on bounding-box center, scale by largest axis) defaulting to 1."}, {"id": "protocols_graphics_place_object", "label": "Place Object Verb (p)", "file_type": "concept", "source_file": "protocols/graphics.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Places a registered object into terminal cell space anchored at row/col spanning w x h cells, with optional animate, scale, depth, color, brightness, translation (px/py/pz), rotation (rx/ry/rz) and non-uniform scale (sx/sy/sz); v1-only clients keep working unchanged."}, {"id": "protocols_graphics_update_object", "label": "Update Object Verb (u)", "file_type": "concept", "source_file": "protocols/graphics.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Updates styling or transform of a placed object in-place without changing its registration or anchor; fields mirror the mutable fields from the place verb."}, {"id": "protocols_graphics_delete_object", "label": "Delete Object Verb (d)", "file_type": "concept", "source_file": "protocols/graphics.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Deletes one object by id, or all Ratty graphics objects when id is omitted."}, {"id": "protocols_graphics_payload_registration", "label": "Payload-based Registration", "file_type": "rationale", "source_file": "protocols/graphics.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Exists for cases such as SSH where the sending application cannot rely on a shared filesystem path on the terminal side: base64 asset bytes are embedded in the register command (source=payload) and may be split into chunks accumulated per id via the more flag until more=0 finalizes registration."}, {"id": "protocols_graphics_inline_object_model", "label": "Inline Terminal Object Model", "file_type": "concept", "source_file": "protocols/graphics.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Each protocol object has an object id, an anchor cell, a cell span, a renderable payload, and optional metadata reserved for future interaction."}, {"id": "protocols_graphics_templeos", "label": "TempleOS", "file_type": "concept", "source_file": "protocols/graphics.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "protocols_graphics_doldoc", "label": "DolDoc Inline Document Graphics", "file_type": "concept", "source_file": "protocols/graphics.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "protocols_graphics_glyph_protocol", "label": "Glyph Protocol", "file_type": "concept", "source_file": "protocols/graphics.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "protocols_graphics_ratty_graphics_protocol", "target": "protocols_graphics_apc_transport", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "protocols/graphics.md", "source_location": null, "weight": 1.0}, {"source": "protocols_graphics_ratty_graphics_protocol", "target": "protocols_graphics_inline_object_model", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "protocols/graphics.md", "source_location": null, "weight": 1.0}, {"source": "protocols_graphics_ratty_graphics_protocol", "target": "protocols_graphics_support_query", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "protocols/graphics.md", "source_location": null, "weight": 1.0}, {"source": "protocols_graphics_ratty_graphics_protocol", "target": "protocols_graphics_register_object_asset", "relation": "references", "c